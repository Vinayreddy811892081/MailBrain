# Server
PORT=5000
NODE_ENV=development

# MongoDB (free tier at mongodb.com/atlas)
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mailbrain?retryWrites=true&w=majority

# JWT Secret (any long random string)
JWT_SECRET=mailbrain_super_secret_key_change_this_in_production_2024

# Anthropic Claude API (get free key at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Razorpay (free account at razorpay.com - for INR payments)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# Your UPI ID for direct payment (PhonePe / GPay / Paytm)
UPI_ID=yourname@upi
UPI_NAME=Your Name

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Subscription price in paise (9900 = ₹99)
SUBSCRIPTION_PRICE=9900
TRIAL_DAYS=5
